# German Clinical NLP Pipeline - Environment Configuration
# Copy this file to .env and update with your settings

# MODEL_PATH (REQUIRED)
# Path to GGUF model file, relative to project root
# Example: models/llama-3.3-70b-instruct-q4_k_m.gguf
# Download from: https://huggingface.co/models?search=llama-3.3+gguf
MODEL_PATH=models/llama-3.3-70b-instruct-q4_k_m.gguf

# MODEL_NAME (Optional)
# Display name for the model (used in API responses)
# Default: "unknown"
MODEL_NAME=Llama 3.3 70B Instruct Q4_K_M

# LOG_LEVEL (Optional)
# Logging verbosity: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO
LOG_LEVEL=INFO
