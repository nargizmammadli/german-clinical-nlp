# German Clinical NLP API - Environment Configuration
# Copy this file to .env and update values before running:
#   cp .env.example .env

# Required: path to the GGUF model file, relative to container WORKDIR /app.
# With docker-compose volume mount ./models:/app/models, this resolves to
# /app/models/mistral-7b-instruct.gguf inside the container.
# Must match the filename of the GGUF file you downloaded to ./models/ on the host.
MODEL_PATH=models/mistral-7b-instruct.gguf

# Optional: human-readable model name shown in GET /models response.
MODEL_NAME=Mistral 7B Instruct Q4_K_M

# Optional: logging verbosity. Valid values: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Optional: confidence threshold for entity filtering (0.0-1.0).
# Entities below this score are moved to the low_confidence array in API responses.
CONFIDENCE_THRESHOLD=0.5

# Optional override example: use Llama 3.3 70B for higher extraction quality (~40GB download)
# MODEL_PATH=models/llama-3.3-70b-instruct.Q4_K_M.gguf
